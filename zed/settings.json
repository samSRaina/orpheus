// Zed settings

// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed

// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "existing_window",
  "telemetry": {
    "diagnostics": true,
    "metrics": true,
  },
  "base_keymap": "JetBrains",
  "icon_theme": "Zed (Default)",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "One Dark",
  },
  "theme_overrides": {
    "One Dark": {
      "border": "#2A2B2CFF",
      "elevated_surface.background": "#111213FF",
      "surface.background": "#111213FF",
      "background": "#121314FF",
      "status_bar.background": "#121314FF",
      "title_bar.background": "#121314FF",
      "toolbar.background": "#111213FF",
      "tab_bar.background": "#111213FF",
      "tab.inactive_background": "#111213FF",
      "tab.active_background": "#111213FF",
      "panel.background": "#111213FF",
      "editor.foreground": "#ACB2BEFF",
      "editor.background": "#111213FF",
      "editor.gutter.background": "#111213FF",
      "editor.subheader.background": "#111213FF",
      "editor.active_line.background": "#2F343EBF",
      "editor.highlighted_line.background": "#111213FF",
      "terminal.background": "#121314FF",
      "panel.overlay_background": "#111213FF",
      "panel.overlay_hover": "#121314FF",
    },
  },
}
